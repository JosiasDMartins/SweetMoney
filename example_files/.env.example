# ============================================================================
# SweetMoney - Environment Variables
# ============================================================================
# Copy this file to .env and adjust values for your environment
#
# IMPORTANT: Django settings (SECRET_KEY, DEBUG, ALLOWED_HOSTS, CSRF_TRUSTED_ORIGINS,
# and EMAIL settings) should be configured in config/local_settings.py, not here.
# This file is for infrastructure configuration only (database, Redis, etc.)
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# ----------------------------------------------------------------------------
# PostgreSQL connection settings (if using PostgreSQL instead of SQLite)
POSTGRES_DB=sweetmoney
POSTGRES_USER=sweetmoney
POSTGRES_PASSWORD=change-this-secure-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ----------------------------------------------------------------------------
# REDIS (Channel Layer for WebSocket & Celery)
# ----------------------------------------------------------------------------
# Redis is used for:
#   - Channel layer for Django Channels WebSocket communication
#   - Message broker for Celery task queue (background jobs, scheduled tasks)
#
# Redis is REQUIRED for Celery functionality
# If Redis is unavailable, the system falls back to InMemoryChannelLayer (WebSocket only)
# and Celery tasks will not run.
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=change-this-redis-password  # Set requirepass in redis for production

# ----------------------------------------------------------------------------
# STARTUP AUTOMATION
# ----------------------------------------------------------------------------
# Run database migrations on container startup (true/false)
AUTO_MIGRATE=true

# Collect static files on container startup (true/false)
AUTO_COLLECTSTATIC=true

# ----------------------------------------------------------------------------
# CELERY (Background Task Queue)
# ----------------------------------------------------------------------------
# Celery is used for background tasks like scheduled notifications
# These settings are typically configured automatically, but can be overridden
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0
# CELERY_TASK_SOFT_TIME_LIMIT=300
# CELERY_TASK_TIME_LIMIT=600

# ----------------------------------------------------------------------------
# ADVANCED SETTINGS (Optional)
# ----------------------------------------------------------------------------
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Log to file (true/false)
# LOG_TO_FILE=true

# Demo mode (for public demonstrations - disables destructive operations)
# DEMO_MODE=false
# DEMO_REPO_URL=https://github.com/yourusername/sweetmoney

# Database connection timeout (seconds)
# DB_TIMEOUT=5

# Maximum upload file size (MB)
# MAX_UPLOAD_SIZE=10

# Session cookie age (seconds) - Default: 2 weeks
# SESSION_COOKIE_AGE=1209600

# NOTE: For more advanced Django settings (HTTPS cookies, email, CSP, etc.),
# edit config/local_settings.py instead of using environment variables
